# Django
SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (desarrollo: sqlite si DATABASE_URL vacío)
DATABASE_URL=

# Correo
# Desarrollo local: consola (default). Gmail SMTP funciona en local.
# Render plan GRATIS: Gmail SMTP NO funciona (puertos bloqueados). Use Brevo:
#   1. Registrarse en https://www.brevo.com (gratis, ~300 correos/día)
#   2. Verificar su Gmail como remitente (Senders)
#   3. Crear API key y configurar BREVO_API_KEY en Render
CPEH_EMAIL_CAPACITACION=capacitacion.cpeh@gmail.com
BREVO_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=capacitacion.cpeh@gmail.com
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=CPEH <capacitacion.cpeh@gmail.com>

# Institucional
CPEH_NOMBRE_COMISION=Comisión Presidencial para la Evaluación de Habitabilidad
CPEH_EVENTO_SISMO_FECHA=2026-06-24
SITE_URL=http://127.0.0.1:8000

